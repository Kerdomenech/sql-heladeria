

/*TABLA CATEGORIAS*/

CREATE TABLE categorias(

id_categoria SERIAL PRIMARY KEY,

nombre_categoria VARCHAR(100) UNIQUE NOT NULL

);



/*TABLA SABORES*/

CREATE TABLE sabores(

id_sabor SERIAL PRIMARY KEY,

nombre_sabor VARCHAR(100) UNIQUE NOT NULL,

id_categoria INT NOT NULL,

FOREIGN KEY(id_categoria)
REFERENCES categorias(id_categoria)

);



/*TABLA UNIDADES DE MEDIDA*/

CREATE TABLE unidades_medidas(

id_unidad_medida SERIAL PRIMARY KEY,

unidad_medida VARCHAR(50) UNIQUE NOT NULL,

abreviatura VARCHAR(10) UNIQUE NOT NULL

);



/*TABLA PRODUCTOS*/

CREATE TABLE productos(

id_producto SERIAL PRIMARY KEY,

nombre_producto VARCHAR(120) UNIQUE NOT NULL,

descripcion VARCHAR(250),

precio NUMERIC(10,2) NOT NULL CHECK(precio>0),

stock INT NOT NULL CHECK(stock>=0),

id_sabor INT NOT NULL,

id_unidad_medida INT NOT NULL,

FOREIGN KEY(id_sabor)
REFERENCES sabores(id_sabor),

FOREIGN KEY(id_unidad_medida)
REFERENCES unidades_medidas(id_unidad_medida)

);



/*TABLA CIUDADES*/

CREATE TABLE ciudades(

id_ciudad SERIAL PRIMARY KEY,

nombre_ciudad VARCHAR(100) NOT NULL,

departamento VARCHAR(100),

pais VARCHAR(100) DEFAULT 'Colombia'

);



/*TABLA PROVEEDORES*/

CREATE TABLE proveedores(

id_proveedor SERIAL PRIMARY KEY,

nombre_proveedor VARCHAR(120) NOT NULL,

nit VARCHAR(20) UNIQUE NOT NULL,

telefono VARCHAR(20),

email VARCHAR(120) UNIQUE,

id_ciudad INT NOT NULL,

FOREIGN KEY(id_ciudad)
REFERENCES ciudades(id_ciudad)

);



/*TABLA CLIENTES*/

CREATE TABLE clientes(

id_cliente SERIAL PRIMARY KEY,

nombre_cliente VARCHAR(120) NOT NULL,

telefono VARCHAR(20),

correo VARCHAR(120) UNIQUE

);



/*TABLA COMPRAS*/

CREATE TABLE compras(

id_compra SERIAL PRIMARY KEY,

fecha_compra DATE NOT NULL,

id_proveedor INT NOT NULL,

FOREIGN KEY(id_proveedor)
REFERENCES proveedores(id_proveedor)

);



/*TABLA DETALLE COMPRAS*/

CREATE TABLE detalle_compras(

id_detalle_compra SERIAL PRIMARY KEY,

id_compra INT NOT NULL,

id_producto INT NOT NULL,

cantidad INT NOT NULL CHECK(cantidad>0),

precio_compra NUMERIC(10,2) NOT NULL,

subtotal NUMERIC(10,2) NOT NULL,

FOREIGN KEY(id_compra)
REFERENCES compras(id_compra),

FOREIGN KEY(id_producto)
REFERENCES productos(id_producto)

);



/*TABLA VENTAS*/

CREATE TABLE ventas(

id_venta SERIAL PRIMARY KEY,

fecha_venta DATE NOT NULL,

id_cliente INT NOT NULL,

FOREIGN KEY(id_cliente)
REFERENCES clientes(id_cliente)

);



/*TABLA DETALLE VENTAS*/

CREATE TABLE detalle_ventas(

id_detalle_venta SERIAL PRIMARY KEY,

id_venta INT NOT NULL,

id_producto INT NOT NULL,

cantidad INT NOT NULL CHECK(cantidad>0),

precio_venta NUMERIC(10,2) NOT NULL,

subtotal NUMERIC(10,2) NOT NULL,

FOREIGN KEY(id_venta)
REFERENCES ventas(id_venta),

FOREIGN KEY(id_producto)
REFERENCES productos(id_producto)

);



/*TABLA MOVIMIENTOS INVENTARIO*/

CREATE TABLE movimientos_inventario(

id_movimiento SERIAL PRIMARY KEY,

fecha_movimiento DATE NOT NULL,

tipo_movimiento VARCHAR(20)
CHECK(tipo_movimiento IN ('Entrada','Salida')),

cantidad INT NOT NULL CHECK(cantidad>0),

id_producto INT NOT NULL,

FOREIGN KEY(id_producto)
REFERENCES productos(id_producto)

);
