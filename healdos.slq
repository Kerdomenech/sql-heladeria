/*CONSULTA 1.Inventario disponible por producto*/

SELECT
    p.nombre_producto,
    p.stock AS inventario_disponible
FROM productos p
ORDER BY inventario_disponible DESC;


/*CONSULTA 2.Productos más vendidos*/

SELECT
    p.nombre_producto,
    SUM(dv.cantidad) AS total_vendido
FROM detalle_ventas dv
INNER JOIN productos p
ON dv.id_producto = p.id_producto
GROUP BY p.nombre_producto
ORDER BY total_vendido DESC;


/*CONSULTA 3.Ventas realizadas por cliente*/

SELECT
    c.nombre_cliente,
    COUNT(v.id_venta) AS total_compras
FROM clientes c
INNER JOIN ventas v
ON c.id_cliente = v.id_cliente
GROUP BY c.nombre_cliente
ORDER BY total_compras DESC;


/*CONSULTA 4.Total vendido por cliente*/

SELECT
    c.nombre_cliente,
    SUM(dv.subtotal) AS total_gastado
FROM clientes c
INNER JOIN ventas v
ON c.id_cliente = v.id_cliente
INNER JOIN detalle_ventas dv
ON v.id_venta = dv.id_venta
GROUP BY c.nombre_cliente
ORDER BY total_gastado DESC;


/*CONSULTA 5.Proveedor con mayor cantidad de compras*/

SELECT
    p.nombre_proveedor,
    COUNT(c.id_compra) AS compras_realizadas
FROM proveedores p
INNER JOIN compras c
ON p.id_proveedor = c.id_proveedor
GROUP BY p.nombre_proveedor
ORDER BY compras_realizadas DESC;


/*CONSULTA 6.Dinero invertido por proveedor*/

SELECT
    p.nombre_proveedor,
    SUM(dc.subtotal) AS total_invertido
FROM proveedores p
INNER JOIN compras c
ON p.id_proveedor = c.id_proveedor
INNER JOIN detalle_compras dc
ON c.id_compra = dc.id_compra
GROUP BY p.nombre_proveedor
ORDER BY total_invertido DESC;


/*CONSULTA 7.Productos por sabor*/

SELECT
    s.nombre_sabor,
    p.nombre_producto
FROM sabores s
INNER JOIN productos p
ON s.id_sabor = p.id_sabor
ORDER BY s.nombre_sabor;


/*CONSULTA 8.Precio promedio de los productos*/

SELECT
AVG(precio) AS precio_promedio
FROM productos;


/*CONSULTA 9.Producto más costoso*/

SELECT
nombre_producto,
precio
FROM productos
ORDER BY precio DESC
LIMIT 1;


/*CONSULTA 10.Producto más económico*/

SELECT
nombre_producto,
precio
FROM productos
ORDER BY precio ASC
LIMIT 1;


/*CONSULTA 11.Productos con menor stock*/

SELECT
nombre_producto,
stock
FROM productos
ORDER BY stock ASC
LIMIT 5;


/*CONSULTA 12.Cantidad de productos por categoría*/

SELECT
    c.nombre_categoria,
    COUNT(*) AS cantidad
FROM categorias c
INNER JOIN sabores s
ON c.id_categoria = s.id_categoria
INNER JOIN productos p
ON s.id_sabor = p.id_sabor
GROUP BY c.nombre_categoria
ORDER BY cantidad DESC;


/*CONSULTA 13.Ventas realizadas por fecha*/

SELECT
fecha_venta,
COUNT(*) AS ventas
FROM ventas
GROUP BY fecha_venta
ORDER BY fecha_venta;


/*CONSULTA 14.Valor total vendido*/

SELECT
SUM(subtotal) AS ventas_totales
FROM detalle_ventas;


/*CONSULTA 15.Detalle completo de ventas*/

SELECT

v.id_venta,
v.fecha_venta,
c.nombre_cliente,
p.nombre_producto,
dv.cantidad,
dv.precio_venta,
dv.subtotal

FROM detalle_ventas dv
INNER JOIN ventas v
ON dv.id_venta = v.id_venta
INNER JOIN clientes c
ON v.id_cliente = c.id_cliente
INNER JOIN productos p
ON dv.id_producto = p.id_producto
ORDER BY v.id_venta;

/*UPDATE.Actualizar el precio de un producto*/

UPDATE productos
SET precio = 8000
WHERE id_producto = 1;

SELECT * FROM productos
WHERE id_producto = 1;



/*UPDATE.Actualizar el stock de un producto*/

UPDATE productos
SET stock = stock + 20
WHERE id_producto = 2;

SELECT * FROM productos
WHERE id_producto = 2;



/*DELETE.Eliminar un cliente*/

DELETE FROM clientes
WHERE id_cliente = 6;

SELECT * FROM clientes;



/*ALTER TABLE.Agregar columna marca*/

ALTER TABLE productos
ADD COLUMN marca VARCHAR(50);



/*Actualizar la nueva columna*/

UPDATE productos
SET marca='Popsy'
WHERE id_producto=1;

UPDATE productos
SET marca='Mimo''s'
WHERE id_producto=2;

UPDATE productos
SET marca='Crem Helado'
WHERE id_producto=3;



/*CREATE VIEW.Vista general de productos*/

CREATE VIEW vista_productos AS

SELECT

p.id_producto,

p.nombre_producto,

s.nombre_sabor,

c.nombre_categoria,

p.precio,

p.stock

FROM productos p

INNER JOIN sabores s

ON p.id_sabor=s.id_sabor

INNER JOIN categorias c

ON s.id_categoria=c.id_categoria;



SELECT * FROM vista_productos;



/*CREATE VIEW.Vista de ventas*/

CREATE VIEW vista_ventas AS

SELECT

v.id_venta,

v.fecha_venta,

cl.nombre_cliente,

p.nombre_producto,

dv.cantidad,

dv.subtotal

FROM detalle_ventas dv

INNER JOIN ventas v

ON dv.id_venta=v.id_venta

INNER JOIN clientes cl

ON v.id_cliente=cl.id_cliente

INNER JOIN productos p

ON dv.id_producto=p.id_producto;



SELECT * FROM vista_ventas;



/*CREATE INDEX*/

CREATE INDEX idx_producto

ON productos(nombre_producto);



CREATE INDEX idx_cliente

ON clientes(nombre_cliente);



CREATE INDEX idx_sabor

ON sabores(nombre_sabor);



